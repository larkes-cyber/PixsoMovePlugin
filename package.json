{
  "name": "pixso-move-lightweight",
  "version": "1.0.0",
  "description": "Pixso plugin for exporting document structure",
  "scripts": {
    "build": "plugin-cli build",
    "postbuild": "node scripts/copy-manifest.js",
    "dev": "plugin-cli dev",
    "lint": "eslint .",
    "format": "prettier . --write",
    "lint:fix": "eslint . --fix && npm run format",
    "pkg": "plugin-cli pkg",
    "typecheck": "npm run typecheck:main && npm run typecheck:ui",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:ui": "tsc --noEmit -p tsconfig.ui.json"
  },
  "keywords": [
    "pixso",
    "plugin"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@pixso/plugin-cli": "1.0.7",
    "@pixso/plugin-typings": "0.5.0",
    "@eslint/js": "9.23.0",
    "eslint": "9.23.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "16.0.0",
    "prettier": "3.5.3",
    "typescript-eslint": "8.46.0",
    "typescript": "5.9.3",
    "webpack-hot-middleware": "2.25.3"
  }
}
